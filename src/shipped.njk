---
layout: base.njk
permalink: /shipped/
title: Shipped
description: "Things I've built and released — from recent experiments to past projects."
---

<div class="shipped-page">
	<h1>Shipped</h1>
	<p>Things I've built and released. Here's what I've shipped so far.</p>

	<div class="shipped-list">
		{% set currentYear = '' %}
		{% for project in collections.shipped | reverse %}
			{% set year = project.date.getFullYear() %}
			{% if year != currentYear %}
				{% set currentYear = year %}
				<h2 class="shipped-list__year">{{ year }}</h2>
			{% endif %}
			<article class="shipped-card">
				<div class="shipped-card__header">
					<h3 class="shipped-card__title">{{ project.data.title }}</h3>
					<time class="shipped-card__date" datetime="{{ project.date | htmlDateString }}">{{ project.date | monthYearDate }}</time>
				</div>
				<p class="shipped-card__description">{{ project.data.description }}</p>
				<div class="shipped-card__links">
					{% if project.data.github %}
					<a href="{{ project.data.github }}" class="shipped-card__link shipped-card__link--github" target="_blank" rel="noopener noreferrer">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77 5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
						GitHub
					</a>
					{% endif %}
					{% if project.data.blog %}
					<a href="{{ project.data.blog | url }}" class="shipped-card__link">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
						Blog
					</a>
					{% endif %}
					{% if project.data.web %}
					<a href="{{ project.data.web }}" class="shipped-card__link" target="_blank" rel="noopener noreferrer">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
						Live Demo
					</a>
					{% endif %}
				</div>
			</article>
		{% endfor %}
	</div>
</div>
