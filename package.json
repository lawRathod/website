{
	"name": "website-11ty",
	"version": "0.0.0",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"dev": "run-p dev:*",
		"start": "eleventy --serve",
		"build": "run-s clean build:assets build:site",
		"dev:assets": "ELEVENTY_ENV=development node esbuild.config.js --watch",
		"dev:site": "ELEVENTY_ENV=development eleventy --serve",
		"build:assets": "ELEVENTY_ENV=production node esbuild.config.js",
		"build:site": "ELEVENTY_ENV=production eleventy",
		"clean": "rm -rf ./public",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@11ty/eleventy": "^3.1.3",
		"@11ty/eleventy-plugin-rss": "^2.0.4",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
		"@biomejs/biome": "^2.4.2",
		"eleventy-plugin-reading-time": "^0.0.1",
		"esbuild": "^0.27.2",
		"luxon": "^3.7.1",
		"npm-run-all": "^4.1.5"
	},
	"dependencies": {
		"eleventy-plugin-toc": "^1.1.5",
		"markdown-it-anchor": "^9.2.0"
	}
}
